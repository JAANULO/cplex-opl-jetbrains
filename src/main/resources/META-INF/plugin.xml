<idea-plugin>
    <id>com.github.cplexopl.opl-support</id>
    <name>CPLEX OPL</name>
    <vendor email="aton.andrzejewski@gmail.com" url="https://github.com/JAANULO/CPLEX-Plugin">Janusz Andrzejewski</vendor>

    <description><![CDATA[
        <h3>CPLEX OPL Support for IntelliJ IDEA</h3>
        <p>Bring the power of IBM ILOG CPLEX Optimization Studio directly into your favorite IDE. This plugin provides essential language support for Optimization Programming Language (OPL).</p>

        <h4>Key Features:</h4>
        <ul>
            <li><b>Syntax Highlighting:</b> Clear syntax coloring for keywords and constraints.</li>
            <li><b>Native Run Configurations:</b> Execute .mod models directly from the editor.</li>
            <li><b>Zero-Config:</b> Automatic detection of the local <i>oplrun</i> engine in the system.</li>
        </ul>
    ]]></description>

    <change-notes><![CDATA[
        <ul>
            <li>Initial release: Support for syntax highlighting and model execution.</li>
            <li>Added automatic CPLEX path detection mechanism.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.cplexopl.settings.OplSettingsState"/>
        <lang.commenter language="OPL" implementationClass="com.github.cplexopl.features.OplCommenter"/>
    <lang.braceMatcher language="OPL" implementationClass="com.github.cplexopl.features.OplPairedBraceMatcher"/>
        <!-- File type -->
        <fileType
                name="OPL Model File"
                implementationClass="com.github.cplexopl.OplFileType"
                fieldName="INSTANCE"
                language="OPL"
                extensions="mod"/>
        <fileType
                name="OPL Data File"
                implementationClass="com.github.cplexopl.OplDatFileType"
                fieldName="INSTANCE"
                language="OPLDat"
                extensions="dat"/>

        <!-- Syntax Highlighting -->
        <lang.syntaxHighlighterFactory
                language="OPL"
                implementationClass="com.github.cplexopl.highlighting.OplSyntaxHighlighterFactory"/>

        <!-- Annotator (real-time error checking) -->
        <annotator
                language="OPL"
                implementationClass="com.github.cplexopl.annotator.OplAnnotator"/>

        <!-- Code Completion -->
        <completion.contributor
                language="OPL"
                implementationClass="com.github.cplexopl.completion.OplCompletionContributor"/>

        <!-- Live Templates -->
        <defaultLiveTemplates file="/liveTemplates/OPL.xml"/>
        <liveTemplateContext contextId="OPL" implementation="com.github.cplexopl.templates.OplTemplateContextType"/>

        <!-- Run Configuration -->
        <configurationType
                implementation="com.github.cplexopl.run.OplRunConfigurationType"/>
        <runConfigurationProducer
                implementation="com.github.cplexopl.run.OplRunConfigurationProducer"/>

        <lang.parserDefinition
                language="OPL"
                implementationClass="com.github.cplexopl.parser.OplParserDefinition"/>
    </extensions>

    <actions>
        <action id="OPL.RunModel"
                class="com.github.cplexopl.actions.RunOplModelAction"
                text="Run OPL Model"
                description="Run current OPL model with CPLEX solver">
            <add-to-group group-id="RunMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="shift F10"/>
        </action>
    </actions>
</idea-plugin>
