{
  parserClass="com.github.cplexopl.parser.OplParser"
  extends="com.intellij.extapi.psi.ASTWrapperPsiElement"

  psiClassPrefix="Opl"
  psiImplClassSuffix="Impl"
  psiPackage="com.github.cplexopl.psi"
  psiImplPackage="com.github.cplexopl.psi.impl"

  elementTypeHolderClass="com.github.cplexopl.psi.OplTypes"
  elementTypeClass="com.github.cplexopl.psi.OplElementType"
  tokenTypeClass="com.github.cplexopl.psi.OplTokenType"

  tokens=[
    // Keywords - reserved words of the OPL language
    USING       = 'using'
    CP          = 'cp'
    INTERVAL    = 'interval'
    SEQUENCE    = 'sequence'
    WITH        = 'with'
    MINIMIZE    = 'minimize'
    MAXIMIZE    = 'maximize'
    SUBJECT     = 'subject'
    FORALL      = 'forall'
    EXISTS      = 'exists'
    IN          = 'in'
    TO          = 'to'
    IF          = 'if'
    ELSE        = 'else'
    THEN        = 'then'
    INT         = 'int'
    FLOAT       = 'float'
    BOOLEAN     = 'boolean'
    STRING      = 'string'
    RANGE       = 'range'
    TUPLE       = 'tuple'
    DVAR        = 'dvar'
    DEXPR       = 'dexpr'
    EXECUTE     = 'execute'
    INCLUDE     = 'include'
    ASSERT      = 'assert'
    SUM         = 'sum'
    ALL         = 'all'
    PULSE       = 'pulse'
    STEP        = 'step'
    ALLDIFFERENT= 'allDifferent'
    PACK        = 'pack'

    // Operators
    SEMICOLON   = ';'
    COLON       = ':'
    COMMA       = ','
    ELLIPSIS    = '...'
    DOTDOT      = '..'
    DOT         = '.'
    EQ          = '='
    EQEQ        = '=='
    NEQ         = '!='
    LT          = '<'
    LE          = '<='
    GT          = '>'
    GE          = '>='
    PLUS        = '+'
    MINUS       = '-'
    STAR        = '*'
    SLASH       = '/'
    ANDAND      = '&&'
    OROR        = '||'
    NOT         = '!'
    MOD         = '%'
    LBRACE      = '{'
    RBRACE      = '}'
    LBRACKET    = '['
    RBRACKET    = ']'
    LPAREN      = '('
    RPAREN      = ')'

    // Token types with regular expressions (regex)
    // Regex is a pattern describing text format, e.g. [0-9]+ = one or more digits
    LINE_COMMENT  = 'regexp://[^\r\n]*'
    BLOCK_COMMENT = 'regexp:/\*([^*]|\*(?!/))*\*/'
    STRING_LITERAL = 'regexp:"([^"\\]|\\.)*"'
    INTEGER_LITERAL = 'regexp:-?[0-9]+'
    FLOAT_LITERAL   = 'regexp:-?[0-9]+\.[0-9]*([eE][+-]?[0-9]+)?'
    ID              = 'regexp:[a-zA-Z_][a-zA-Z0-9_]*'
  ]
}

// Root rule: an OPL file is a sequence of declarations
oplFile ::= item_*
private item_ ::= declaration | SEMICOLON

// Declaration can be of various types
declaration ::= varDeclaration
              | dvarDeclaration
              | objectiveDeclaration
              | constraintSection
              | executeBlock
              | tupleDeclaration
              | includeDeclaration
              | usingDeclaration

// Data variable declaration (supports arrays, ellipses, and ranges)
varDeclaration ::= (INT | FLOAT | BOOLEAN | STRING | RANGE) ID (LBRACKET expression RBRACKET)* (EQ (ELLIPSIS | expression))? SEMICOLON { 
  pin=2 
  recoverWhile=statement_recover 
  implements="com.github.cplexopl.psi.OplNamedElement"
  mixin="com.github.cplexopl.psi.OplNamedElementImpl"
}

// Using declaration (enables CP engine)
usingDeclaration ::= USING CP SEMICOLON { pin=1 recoverWhile=statement_recover }

// Decision variable declaration (supports arrays)
dvarDeclaration ::= DVAR (INT | FLOAT | BOOLEAN | INTERVAL | SEQUENCE) ID (LBRACKET expression RBRACKET)* (IN rangeExpression)? SEMICOLON { 
  pin=1 
  recoverWhile=statement_recover 
  implements="com.github.cplexopl.psi.OplNamedElement"
  mixin="com.github.cplexopl.psi.OplNamedElementImpl"
}

// Objective function - what we minimize/maximize
objectiveDeclaration ::= (MINIMIZE | MAXIMIZE) expression SEMICOLON { pin=1 recoverWhile=statement_recover }

// Constraint section
constraintSection ::= SUBJECT TO LBRACE constraintItem* RBRACE { pin=1 }

// Iterator definition for loops and sums (e.g. i in 1..9 : x != 0)
oplIterator ::= ID IN expression (COLON constraintExpression)?

// Conflict guard: optional label (private to avoid breaking Annotator)
private label ::= ID COLON

constraintItem ::= label? constraintExpression SEMICOLON
                 | FORALL LPAREN oplIterator (COMMA oplIterator)* RPAREN LBRACE constraintItem* RBRACE
                 | FORALL LPAREN oplIterator (COMMA oplIterator)* RPAREN constraintItem

// Hidden helper rule: constraint may (but need not) have a relational operator
private constraintExpression ::= expression ((LE | LT | GT | GE | EQ | EQEQ | NEQ) expression)?

// Execute block - IBM Script code (JavaScript-like)
executeBlock ::= EXECUTE ID? executeBody { pin=1 recoverWhile=statement_recover }
executeBody ::= LBRACE executeItem* RBRACE
private executeItem ::= executeBody | executeToken
private executeToken ::= ID | INTEGER_LITERAL | FLOAT_LITERAL | STRING_LITERAL | LPAREN | RPAREN | LBRACKET | RBRACKET | PLUS | MINUS | STAR | SLASH | EQ | EQEQ | NEQ | LT | LE | GT | GE | SEMICOLON | COMMA | DOT | DOTDOT | ELLIPSIS | COLON | INT | FLOAT | BOOLEAN | STRING | RANGE | DVAR | DEXPR | TUPLE | MINIMIZE | MAXIMIZE | SUBJECT_TO | INCLUDE | EXECUTE | FORALL | EXISTS | IN | TO | IF | ELSE | THEN | USING | CP | INTERVAL | SEQUENCE | WITH | ASSERT | SUM | ALL | PULSE | STEP | ALLDIFFERENT | PACK | ANDAND | OROR | NOT | MOD

// Tuple declaration (struct-like type)
tupleDeclaration ::= TUPLE ID LBRACE tupleField* RBRACE SEMICOLON { 
  pin=1 
  recoverWhile=statement_recover 
  implements="com.github.cplexopl.psi.OplNamedElement"
  mixin="com.github.cplexopl.psi.OplNamedElementImpl"
}
tupleField ::= (INT | FLOAT | STRING | ID) ID SEMICOLON { pin=2 }

// Include another file
includeDeclaration ::= INCLUDE STRING_LITERAL SEMICOLON { pin=1 }

// Expressions (simplified)
// Ranges - allows the parser to understand notation like 1..NbItems
rangeExpression ::= additiveExpression DOTDOT additiveExpression

expression ::= rangeExpression | additiveExpression
private additiveExpression ::= term ((PLUS | MINUS) term)*
term ::= factor ((STAR | SLASH) factor)*

// Extended factor: supports sums, all loops, CP functions, arrays, numbers and variables
factor ::= (PLUS | MINUS) factor
         | (SUM | ALL) LPAREN oplIterator (COMMA oplIterator)* RPAREN expression
         | (ID | ALLDIFFERENT | PACK | PULSE | STEP) ( LPAREN (expression (COMMA expression)*)? RPAREN )? (LBRACKET expression RBRACKET)*
         | INTEGER_LITERAL
         | FLOAT_LITERAL
         | STRING_LITERAL
         | LBRACKET (expression (COMMA expression)*)? RBRACKET
         | LPAREN expression RPAREN

// Recovery rule: "Skip everything until a new declaration start or semicolon"
private statement_recover ::= !(INT | FLOAT | BOOLEAN | INTERVAL | SEQUENCE | STRING | RANGE | DVAR | TUPLE | MINIMIZE | MAXIMIZE | SUBJECT | INCLUDE | EXECUTE | USING | SEMICOLON | RBRACE)
